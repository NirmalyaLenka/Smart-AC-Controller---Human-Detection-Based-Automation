/*
  config_secrets.h - Private Credentials
  ----------------------------------------
  This file holds your WiFi name and password.
  It is listed in .gitignore so it will NOT be
  uploaded to GitHub by accident.

  DO NOT share this file with anyone.

  HOW TO USE:
  1. Rename this file from config_secrets.h.example
     to config_secrets.h
  2. Fill in your actual WiFi credentials below
  3. Include this file in your .ino instead of
     hardcoding credentials

  In your .ino file, add at the top:
    #include "config_secrets.h"

  Then use WIFI_SSID and WIFI_PASSWORD as your
  WiFi name and password variables.
*/

#ifndef CONFIG_SECRETS_H
#define CONFIG_SECRETS_H

#define WIFI_SSID     "your_wifi_name_here"
#define WIFI_PASSWORD "your_wifi_password_here"

#endif // CONFIG_SECRETS_H
